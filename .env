# ==============================================================================
# ZTRACK API - Variables para Docker (conexión externa)
# ==============================================================================
# Copiar a .env cuando uses: docker compose -f docker-compose.external.yml up -d
#
# MongoDB en el host o externo:
# MONGO_DETAILS_OK=mongodb://host.docker.internal:27017
# MONGO_DETAILS_OK=mongodb://192.168.1.100:27017
# MONGO_DETAILS_OK=mongodb+srv://user:pass@cluster.mongodb.net/
#
# Redis en el host o externo:
# REDIS_HOST=host.docker.internal
# REDIS_HOST=192.168.1.100
#
# BD_DETAILS_OK=ztrack_db
# REDIS_PORT=6379
# ==============================================================================

