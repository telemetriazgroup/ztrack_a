# ==============================================================================
# ZTRACK API - Variables para Docker
# ==============================================================================
# Copiar a .env:  cp .env.docker.example .env
#
# --- MongoDB PRINCIPAL (en el servidor, no en contenedor) --------------------
# Si Mongo escucha en el host (127.0.0.1), desde los contenedores usa:
#   host.docker.internal  (requiere Docker 20.10+ con extra_hosts en compose)
# O la IP del servidor en la red (ej. 10.0.0.5).
#
# MONGO_DETAILS_OK=mongodb://host.docker.internal:27017
# MONGO_DETAILS_OK=mongodb://usuario:clave@host.docker.internal:27017/?authSource=admin
# MONGO_DETAILS_OK=mongodb://192.168.1.10:27017
#
MONGO_DETAILS_OK=mongodb://host.docker.internal:27017
BD_DETAILS_OK=ztrack_db

# --- MongoDB RESPALDO (opcional; URI completa “por enlace”) -------------------
# Atlas, otro host, otro puerto, etc. Vacío = no se duplica a respaldo.
# MONGO_BACKUP_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/
# MONGO_BACKUP_URI=mongodb://otro-servidor:27017
# MONGO_BACKUP_DB=ztrack_db

# --- Redis (compose principal usa servicio redis:6379; aquí todo externo) -----
# REDIS_HOST=host.docker.internal
# REDIS_PORT=6379
