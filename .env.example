# ==============================================================================
# ZTRACK API - Variables de Entorno
# ==============================================================================
# Docker + compose: el default en docker-compose.yml ya usa host.docker.internal
# para llegar al Mongo del host (equivalente a mongodb://localhost:27017 en el SO).
# Si corres la app en el host sin Docker, usa mongodb://localhost:27017 aquí.
# Redis en compose: servicio interno; en el host el puerto publicado es 6380.
# ==============================================================================

# MongoDB principal
# Sin Docker (Python en el mismo equipo que Mongo):
MONGO_DETAILS_OK=mongodb://localhost:27017
# Con Docker, en .env suele sobreescribirse a (o omite y usa el default del compose):
# MONGO_DETAILS_OK=mongodb://host.docker.internal:27017
BD_DETAILS_OK=ztrack_db

# MongoDB respaldo (opcional): duplica escrituras de Starcool, Generador y Datos.
# Si no responde en ~2s al arrancar, se ignora el respaldo (solo Mongo principal).
# MONGO_BACKUP_URI=mongodb+srv://user:pass@cluster.mongodb.net/
# MONGO_BACKUP_DB=ztrack_db_backup
# MONGO_BACKUP_CONNECT_TIMEOUT_MS=2000
# MONGO_BACKUP_SERVER_SELECTION_TIMEOUT_MS=2000

# Redis (Docker usa redis interno; para instalación manual)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Zona horaria para fechas (Docker usa UTC; datos históricos en GMT-5)
APP_TIMEZONE=America/Lima

# Aplicación
# development = /docs y /redoc habilitados, reload en uvicorn
# production = docs deshabilitados (seguridad)
APP_ENV=development
# ENABLE_DOCS=true  # Opcional: forzar /docs incluso en production
APP_PORT=9050
APP_DEBUG=false

# Seguridad Progresiva (false = aceptar dispositivos sin API Key)
ENABLE_AUTH=false
LEGACY_ACCEPT=true

# Batch Writer
BATCH_SIZE=50
BATCH_TIMEOUT_SECONDS=2.0

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
