# ==============================================================================
# ZTRACK API - Variables de Entorno
# ==============================================================================
# Docker (docker-compose.yml): MONGO_DETAILS_OK y BD_DETAILS_OK son obligatorios.
# Redis se configura internamente; en host usa puerto 6380 (evita conflicto).
# ==============================================================================

# MongoDB (obligatorio para Docker)
MONGO_DETAILS_OK=mongodb://localhost:27017
BD_DETAILS_OK=ztrack_db
# Ejemplos: mongodb://host:27017 | mongodb+srv://user:pass@cluster.mongodb.net/

# MongoDB respaldo (opcional): duplica escrituras de Starcool, Generador y Datos.
# Si MONGO_BACKUP_URI está vacío, no se usa respaldo.
# MONGO_BACKUP_DB vacío = mismo nombre que BD_DETAILS_OK.
# MONGO_BACKUP_URI=mongodb://otro-host:27017
# MONGO_BACKUP_DB=ztrack_db_backup

# Redis (Docker usa redis interno; para instalación manual)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Zona horaria para fechas (Docker usa UTC; datos históricos en GMT-5)
APP_TIMEZONE=America/Lima

# Aplicación
# development = /docs y /redoc habilitados, reload en uvicorn
# production = docs deshabilitados (seguridad)
APP_ENV=development
# ENABLE_DOCS=true  # Opcional: forzar /docs incluso en production
APP_PORT=9050
APP_DEBUG=false

# Seguridad Progresiva (false = aceptar dispositivos sin API Key)
ENABLE_AUTH=false
LEGACY_ACCEPT=true

# Batch Writer
BATCH_SIZE=50
BATCH_TIMEOUT_SECONDS=2.0

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
